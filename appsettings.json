{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=YOUR_DATABASE;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;"
  },

  "Firebase": {
    "ServiceAccountPath": "path/to/firebase-service-account.json",
    "ServiceAccountJson": "YOUR_FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON"
  },

  "FirebaseMagicLink": {
    "ContinueUrl": "http://localhost:4200/login",
    "HandleCodeInApp": true
  },

  "SendGrid": {
    "ApiKey": "YOUR_SENDGRID_API_KEY",

    "FromEmail": "noreply@yourdomain.com",
    "FromName": "World Cup Predictor",

    "TemplateId": "FIREBASE_DEFAULT_MAGIC_LINK_TEMPLATE_ID",

    "TemplateIdEn": "MAGIC_LINK_TEMPLATE_ID_ENGLISH",
    "TemplateIdEs": "MAGIC_LINK_TEMPLATE_ID_SPANISH",

    "InvitationTemplateId": "GROUP_INVITATION_TEMPLATE_ID",

    "InvitationTemplateIdEs": "GROUP_INVITATION_TEMPLATE_ID_SPANISH",
    "InvitationTemplateIdEn": "GROUP_INVITATION_TEMPLATE_ID_ENGLISH"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "S3Storage": {
    "BucketName": "your-s3-bucket-name",
    "Region": "us-east-1",

    "UploadExpirationMinutes": 5,
    "ReadExpirationMinutes": 10,

    "MaxFileSizeBytes": 3145728,

    "AllowedContentTypes": [
      "image/jpeg",
      "image/png",
      "image/webp"
    ]
  },

  "AWS": {
    "AccessKeyId": "YOUR_AWS_ACCESS_KEY_ID",
    "SecretAccessKey": "YOUR_AWS_SECRET_ACCESS_KEY"
  },

  "Recaptcha": {
    "SecretKey": "YOUR_RECAPTCHA_SECRET_KEY",
    "MinimumScore": 0.5
  },

  "Frontend": {
    "BaseUrl": "http://localhost:4200"
  },

  "AllowedHosts": "*"
}